{
  "name": "delivio",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=delivio-backend --filter=@delivio/customer --filter=@delivio/vendor --filter=@delivio/rider --filter=@delivio/superadmin",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
