{
  "expo": {
    "name": "Delivio Vendor",
    "slug": "delivio-vendor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "delivio-vendor",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.delivio.vendor"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.delivio.vendor"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      ["expo-notifications"]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
