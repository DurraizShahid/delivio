# =============================================================
# Delivio Backend — Environment Variables
# Copy to .env and fill in your values.
# Variables marked REQUIRED must be set before starting.
# Variables marked OPTIONAL have graceful fallbacks.
# =============================================================

# ---------------------------------------------------------------
# Server
# ---------------------------------------------------------------
PORT=8080
NODE_ENV=development                          # production | development | test

# Public URL of this API (no trailing slash). Used for absolute logo URLs from file uploads.
# In production behind a reverse proxy, set to your public API origin (e.g. https://api.example.com).
# OPTIONAL — if unset, the upload handler uses the incoming Host / X-Forwarded-* headers.
PUBLIC_SERVER_URL=

# ---------------------------------------------------------------
# Frontend clients (OPTIONAL)
# If not set, web apps default to localhost in dev and Railway URL in prod.
# ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080

# ---------------------------------------------------------------
# Mobile clients (OPTIONAL)
# If not set, Expo apps default to localhost in dev and Railway URL in prod.
# ---------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8080

# ---------------------------------------------------------------
# Security (REQUIRED)
# ---------------------------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ---------------------------------------------------------------
# CORS (REQUIRED in production)
# Comma-separated list of allowed frontend origins.
# Example: https://app.delivio.com,https://admin.delivio.com
# ---------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ---------------------------------------------------------------
# Supabase (REQUIRED)
# ---------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token    # Management API

# ---------------------------------------------------------------
# Redis (OPTIONAL — falls back to in-memory store)
# WARNING: In-memory store is NOT suitable for multi-process/production.
# Set REDIS_URL to enable persistent sessions across restarts.
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------
# Twilio SMS (OPTIONAL — falls back to console.log in dev)
# Required for production phone OTP authentication.
# ---------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ---------------------------------------------------------------
# Transactional Email (OPTIONAL — falls back to console.log in dev)
# EMAIL_PROVIDER: resend | sendgrid | postmark
# ---------------------------------------------------------------
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ---------------------------------------------------------------
# Stripe Payments (OPTIONAL — falls back to dummy processor)
# Required for live payment processing.
# ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# Firebase Push Notifications (OPTIONAL — skipped if not set)
# Paste the full service account JSON as a single line.
# ---------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ---------------------------------------------------------------
# Google Maps (REQUIRED for geocoding proxy)
# ---------------------------------------------------------------
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# Sentry Error Tracking (OPTIONAL)
# ---------------------------------------------------------------
SENTRY_DSN=https://xxxx@oxxxxxxx.ingest.sentry.io/xxxxx

# ---------------------------------------------------------------
# JWT (used for WebSocket ?token= auth)
# ---------------------------------------------------------------
JWT_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=7d
